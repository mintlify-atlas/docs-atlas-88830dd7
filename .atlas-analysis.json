  "keyFeatures": [
    "On-device LLM execution with Llama and Qwen models",
    "Computer vision tasks (classification, object detection, segmentation, OCR)",
    "Speech processing (speech-to-text, text-to-speech, voice activity detection)",
    "Text and image embeddings for semantic search",
    "Tool calling and function execution for LLMs",
    "Declarative React hooks API for all AI capabilities",
    "Support for both Expo and bare React Native projects",
    "Optimized model loading with progress tracking"
  ],
